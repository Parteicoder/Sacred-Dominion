    </Row>
    <Row Tag="LOC_SACRED_DOMINION_BELIEF_CHARITABLE_WORKS_DESCRIPTION" Language="en_US">
      <Text>Shrines and Temples provide +1 Food.</Text>
    </Row>
    <Row Tag="LOC_SACRED_DOMINION_BELIEF_PILGRIMAGE_NETWORK_NAME" Language="en_US">
      <Text>Pilgrimage Network</Text>
    </Row>
    <Row Tag="LOC_SACRED_DOMINION_BELIEF_PILGRIMAGE_NETWORK_DESCRIPTION" Language="en_US">
